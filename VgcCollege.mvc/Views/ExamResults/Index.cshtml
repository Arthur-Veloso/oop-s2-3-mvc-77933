@model IEnumerable<VgcCollege.Domain.Models.ExamResult>

@{
    ViewData["Title"] = "My Results";
}

<h1>My Results</h1>

@if (!Model.Any())
{
    <p class="text-muted">No results available yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Exam</th>
                <th>Score</th>
                <th>Grade</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Exam.Title</td>
                    <td>@item.Score</td>
                    <td>@item.Grade</td>
                </tr>
            }
        </tbody>
    </table>
}