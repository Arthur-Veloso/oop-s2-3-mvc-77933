@model VgcCollege.Domain.Models.StudentProfile

<h2 class="mb-4">Student Details</h2>

<div class="card shadow-sm p-4 mb-4">

    <div class="d-flex align-items-center mb-3">
        <div class="bg-success text-white rounded-circle me-3 d-flex justify-content-center align-items-center"
             style="width:50px;height:50px;font-size:20px;">
            @Model.Name.Substring(0, 1)
        </div>

        <div>
            <h4 class="mb-0">@Model.Name</h4>
            <small class="text-muted">@Model.StudentNumber</small>
        </div>
    </div>

    <hr />

    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Phone:</strong> @Model.Phone</p>
    <p><strong>Address:</strong> @Model.Address</p>

</div>

<!-- 🔥 ADD THIS SECTION HERE -->
<h4>Enrolled Courses</h4>

@if (Model.Enrolments != null && Model.Enrolments.Any())
{
    <ul class="list-group mb-4">
        @foreach (var enrol in Model.Enrolments)
        {
            <li class="list-group-item">
                @enrol.Course.Name
            </li>
        }
    </ul>
}
else
{
    <p class="text-muted">No courses enrolled.</p>
}

<!-- Buttons -->
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>