@model VgcCollege.Domain.Models.Branch

<h1 class="mb-3">Branch Details</h1>

<div class="card p-3 mb-4">
    <h4>@Model.Name</h4>
    <p class="text-muted">@Model.Address</p>
</div>

<h4>Courses in this Branch</h4>

@if (Model.Courses != null && Model.Courses.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Course Name</th>
                <th>Start</th>
                <th>End</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model.Courses)
            {
                <tr>
                    <td>@course.Name</td>
                    <td>@course.StartDate.ToShortDateString()</td>
                    <td>@course.EndDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No courses assigned to this branch.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
