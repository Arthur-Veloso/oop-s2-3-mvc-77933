@model IEnumerable<VgcCollege.Domain.Models.StudentProfile>

@{
    ViewData["Title"] = "Students";
}

<h2 class="mb-4">👨‍🎓 My Students</h2>

<div class="card shadow-lg border-0">
    <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle me-2 d-flex justify-content-center align-items-center"
                                     style="width:40px;height:40px;">
                                    @item.Name.Substring(0, 1)
                                </div>

                                <div>
                                    <strong>@item.Name</strong><br />
                                    <small class="text-muted">@item.StudentNumber</small>
                                </div>
                            </div>
                        </td>

                        <td>@item.Email</td>
                        <td>@item.Phone</td>

                        <td>
                            <a asp-controller="Students" asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">View</a>

                            <a asp-controller="ExamResults" asp-action="Index"
                               class="btn btn-sm btn-success">Results</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>