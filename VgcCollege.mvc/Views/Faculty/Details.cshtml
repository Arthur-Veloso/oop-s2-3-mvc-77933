@using System.Linq
@model VgcCollege.Domain.Models.FacultyProfile

<h2 class="mb-4">Faculty Details</h2>

<div class="card shadow-sm p-4 mb-4">
    <h4>@Model.Name</h4>
    <p class="text-muted mb-1">@Model.Email</p>
    <p class="text-muted">@Model.Phone</p>
</div>

<h4>Assigned Courses</h4>

@if (Model.Courses != null && Model.Courses.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Course</th>
                <th>Branch</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model.Courses)
            {
                <tr>
                    <td>@course.Name</td>
                    <td>@(course.Branch != null ? course.Branch.Name : "No Branch")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No courses assigned.</p>
}

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>