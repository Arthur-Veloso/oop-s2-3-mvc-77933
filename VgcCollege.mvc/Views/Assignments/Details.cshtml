@model VgcCollege.Domain.Models.Assignment

<h2 class="mb-4">Assignment Details</h2>

<div class="card shadow-sm p-4">

    <h4>@Model.Title</h4>

    <p><strong>Course:</strong> @Model.Course?.Name</p>
    <p><strong>Max Score:</strong> @Model.MaxScore</p>
    <p><strong>Due Date:</strong> @Model.DueDate.ToShortDateString()</p>

</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>