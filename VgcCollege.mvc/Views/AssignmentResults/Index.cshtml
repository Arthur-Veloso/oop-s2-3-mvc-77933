@model IEnumerable<VgcCollege.Domain.Models.AssignmentResult>

@{
    ViewData["Title"] = "Assignment Results";
}

<h2 class="mb-4">📝 Assignment Results</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Add Result</a>
</p>

<div class="card shadow-lg border-0">
    <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Assignment</th>
                    <th>Student</th>
                    <th>Score</th>
                    <th>Feedback</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Assignment?.Title</strong><br />
                            <small class="text-muted">@item.Assignment?.Course?.Name</small>
                        </td>

                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-success text-white rounded-circle me-2 d-flex justify-content-center align-items-center"
                                     style="width:35px;height:35px;">
                                    @item.Student?.Name.Substring(0, 1)
                                </div>
                                @item.Student?.Name
                            </div>
                        </td>

                        <td>
                            <span class="badge bg-primary">
                                @item.Score
                            </span>
                        </td>

                        <td>@item.Feedback</td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">Edit</a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>
