@model VgcCollege.Domain.Models.Exam

@{
    ViewData["Title"] = "Exam Details";
}

<h2 class="mb-4">📄 Exam Details</h2>

<div class="card shadow-sm p-4">

    <h4 class="fw-bold mb-3">@Model.Title</h4>

    <p class="text-muted mb-2">
        <strong>Course:</strong> @Model.Course?.Name
    </p>

    <p>
        <strong>Date:</strong> @Model.Date.ToString("dd MMM yyyy")
    </p>

    <p>
        <strong>Max Score:</strong>
        <span class="badge bg-info text-dark">@Model.MaxScore</span>
    </p>

    <p>
        <strong>Status:</strong>
        @if (Model.Date < DateTime.Now)
        {
            <span class="badge bg-secondary">Completed</span>
        }
        else
        {
            <span class="badge bg-success">Upcoming</span>
        }
    </p>

    <hr />

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</div>