@model IEnumerable<VgcCollege.Domain.Models.CourseEnrolment>

<h2 class="mb-4">Course Enrolments</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Enrol Student</a>
</p>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Student.Name</td>
                <td>@item.Course.Name</td>
                <td>@item.EnrolDate.ToShortDateString()</td>

                <td>
                    @if (item.Status == "Active")
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Status</span>
                    }
                </td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>