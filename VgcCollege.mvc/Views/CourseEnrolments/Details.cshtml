@model VgcCollege.Domain.Models.CourseEnrolment

<h2 class="mb-4">Enrolment Details</h2>

<div class="card shadow-sm p-4">

    <h4 class="mb-3">@Model.Course.Name</h4>

    <p><strong>Student:</strong> @Model.Student.Name</p>
    <p><strong>Email:</strong> @Model.Student.Email</p>

    <hr />

    <p><strong>Enrol Date:</strong> @Model.EnrolDate.ToShortDateString()</p>

    <p>
        <strong>Status:</strong>
        @if (Model.Status == "Active")
        {
            <span class="badge bg-success">Active</span>
        }
        else
        {
            <span class="badge bg-secondary">@Model.Status</span>
        }
    </p>

</div>

<br />

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>