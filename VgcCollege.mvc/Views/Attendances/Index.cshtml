@model IEnumerable<VgcCollege.Domain.Models.Attendance>

@{
    ViewData["Title"] = "Attendance";
}

<h2 class="mb-4">📅 Attendance Management</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create Attendance</a>
</p>

<div class="card shadow-lg border-0">
    <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle me-2 d-flex justify-content-center align-items-center"
                                     style="width:35px;height:35px;">
                                    @item.Student?.Name.Substring(0, 1)
                                </div>
                                @item.Student?.Name
                            </div>
                        </td>

                        <td>
                            <strong>@item.Course?.Name</strong>
                        </td>

                        <td>
                            <small class="text-muted">
                                @item.Date.ToString("dd MMM yyyy")
                            </small>
                        </td>

                        <td>
                            @if (item.IsPresent)
                            {
                                <span class="badge bg-success">Present</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Absent</span>
                            }
                        </td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">Edit</a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>