@model VgcCollege.Domain.Models.Attendance

<h2 class="mb-4">📅 Create Attendance</h2>

<div class="card shadow-lg p-4">

    <form asp-action="Create" method="post">

        @Html.AntiForgeryToken()

        <!-- 🔴 SHOW ERRORS -->
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label>Student</label>
                <select asp-for="StudentProfileId"
                        asp-items="ViewBag.StudentProfileId"
                        class="form-control"></select>
            </div>

            <div class="col-md-6 mb-3">
                <label>Course</label>
                <select asp-for="CourseId"
                        asp-items="ViewBag.CourseId"
                        class="form-control"></select>
            </div>

            <div class="col-md-6 mb-3">
                <label>Date</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>

            <div class="col-md-6 mb-3 mt-4">
                <input asp-for="IsPresent" type="checkbox" />
                <label> Present</label>
            </div>

        </div>

        <button type="submit" class="btn btn-primary">Save</button>

    </form>

</div>